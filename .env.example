# Application
CODEWIKI_APP_NAME=Code Wiki Platform
CODEWIKI_DATABASE_URL=sqlite+aiosqlite:///./data/codewiki.sqlite3
CODEWIKI_STORAGE_DIR=./storage

# LLM routing mode. Keep "sdk" for direct LiteLLM SDK calls.
CODEWIKI_LLM_MODE=sdk

# Default LLM profile. All tasks inherit these values unless a task-specific
# override below is set. Model may include a LiteLLM provider prefix, for example
# "openai/gpt-4.1" or "anthropic/claude-sonnet-4-5".
CODEWIKI_LLM_MODEL=provider/strong-coding-model
CODEWIKI_LLM_PROVIDER=
CODEWIKI_LLM_ENDPOINT=
CODEWIKI_LLM_API_KEY=

# Catalog generation override. Use a fast/cheap model here if desired.
CODEWIKI_LLM_CATALOG_MODEL=
CODEWIKI_LLM_CATALOG_PROVIDER=
CODEWIKI_LLM_CATALOG_ENDPOINT=
CODEWIKI_LLM_CATALOG_API_KEY=

# Community summary / cluster naming override.
CODEWIKI_LLM_COMMUNITY_MODEL=
CODEWIKI_LLM_COMMUNITY_PROVIDER=
CODEWIKI_LLM_COMMUNITY_ENDPOINT=
CODEWIKI_LLM_COMMUNITY_API_KEY=

# Wiki page generation override. Use a stronger model for source-grounded pages.
CODEWIKI_LLM_PAGE_MODEL=
CODEWIKI_LLM_PAGE_PROVIDER=
CODEWIKI_LLM_PAGE_ENDPOINT=
CODEWIKI_LLM_PAGE_API_KEY=

# Wiki translation override. Leave empty to use the default LLM profile.
CODEWIKI_LLM_TRANSLATION_MODEL=
CODEWIKI_LLM_TRANSLATION_PROVIDER=
CODEWIKI_LLM_TRANSLATION_ENDPOINT=
CODEWIKI_LLM_TRANSLATION_API_KEY=

# Ask/QA override. Streaming is enabled for this task by default.
CODEWIKI_LLM_QA_MODEL=
CODEWIKI_LLM_QA_PROVIDER=
CODEWIKI_LLM_QA_ENDPOINT=
CODEWIKI_LLM_QA_API_KEY=

# Embedding override. Set this when your default model is not an embedding model
# and GraphRAG vector indexing is enabled.
CODEWIKI_LLM_EMBEDDING_MODEL=
CODEWIKI_LLM_EMBEDDING_PROVIDER=
CODEWIKI_LLM_EMBEDDING_ENDPOINT=
CODEWIKI_LLM_EMBEDDING_API_KEY=

# Wiki language settings. Base language is generated first; translation
# languages are comma-separated, for example "zh,ja,ko". Set "zh" to keep
# the Chinese Wiki view populated after generating the base language.
CODEWIKI_WIKI_BASE_LANGUAGE=en
CODEWIKI_WIKI_TRANSLATION_LANGUAGES=
