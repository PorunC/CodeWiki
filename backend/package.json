{
  "name": "@misaka09982/code-wiki",
  "version": "0.7.6",
  "description": "TypeScript backend for CodeWiki with repository analysis, graph APIs, wiki drafts, and Q&A endpoints.",
  "type": "module",
  "license": "MIT",
  "author": "PorunC <09982.misaka@gmail.com>",
  "homepage": "https://github.com/PorunC/CodeWiki",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PorunC/CodeWiki.git",
    "directory": "backend"
  },
  "bugs": {
    "url": "https://github.com/PorunC/CodeWiki/issues"
  },
  "keywords": [
    "codewiki",
    "code-wiki",
    "graphrag",
    "fastify",
    "documentation",
    "sqlite",
    "typescript"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codewiki": "dist/cli.js",
    "codewiki-backend": "dist/cli.js",
    "codewiki-mcp": "dist/mcp/stdio.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/http/server.d.ts",
      "default": "./dist/http/server.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "default": "./dist/mcp/server.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json",
    "scripts/check-ports.mjs",
    "scripts/verify-release-version.mjs",
    "skills",
    "static"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-prompts.mjs",
    "build:frontend": "npm --prefix ../frontend run build",
    "check:ports": "node scripts/check-ports.mjs",
    "clean": "rimraf dist coverage",
    "dev": "tsx watch src/cli.ts",
    "format:check": "prettier --check src test scripts package.json vitest.config.ts",
    "lint": "eslint src test vitest.config.ts --ext .ts && npm run format:check",
    "pack:dry": "node scripts/package-dry-run.mjs",
    "pack:smoke": "node scripts/package-smoke.mjs",
    "prepack": "npm run build && npm run build:frontend",
    "release:verify": "node scripts/verify-release-version.mjs",
    "start": "node dist/cli.js serve",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/static": "^9.1.3",
    "commander": "^12.1.0",
    "fastify": "^5.2.1",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "ignore": "^7.0.3",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.8"
  }
}
